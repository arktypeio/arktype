{
	"name": "arktype",
	"displayName": "ArkType",
	"description": "Syntax highlighting and inline errors for ArkType⛵",
	"version": "6.0.0",
	"publisher": "arktypeio",
	"license": "MIT",
	"scripts": {
		"package": "vsce package --out syntax.vsix",
		"publish": "vsce publish -i syntax.vsix"
	},
	"engines": {
		"vscode": "^1.0.0"
	},
	"categories": [
		"Programming Languages"
	],
	"extensionDependencies": [
		"usernamehw.errorlens"
	],
	"contributes": {
		"grammars": [
			{
				"injectTo": [
					"source.ts",
					"source.tsx",
					"source.js",
					"source.jsx",
					"source.mdx",
					"text.html.markdown"
				],
				"scopeName": "source.arktype.injection.ts",
				"path": "injected.tmLanguage.json"
			}
		],
		"configurationDefaults": {
			"editor.quickSuggestions": {
				"strings": "on"
			},
			"errorLens.followCursor": "closestProblem",
			"errorLens.delay": 0,
			"errorLens.editorHoverPartsEnabled": {
				"buttonsEnabled": false
			},
			"errorLens.replace": [
				{
					"matcher": ".*'ErrorType<(.*)>'.*$",
					"message": "$1"
				},
				{
					"matcher": ".*'\"(.*\\u200A)\"'\\.$",
					"message": "$1"
				},
				{
					"matcher": "^(?:Type|Argument of type) '\"(.*)\"' is not assignable to (?:parameter of )?type '(\"\\1.*\")'\\.$",
					"message": "$2"
				},
				{
					"matcher": "[^]*\n([^\n]*)$",
					"message": "$1"
				}
			]
		}
	}
}
