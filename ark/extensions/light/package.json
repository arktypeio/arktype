{
	"name": "arklight",
	"displayName": "ArkLight",
	"description": "Light theme with special highlighting for TypeScript generics ⛵",
	"version": "6.0.0",
	"publisher": "arktypeio",
	"license": "MIT",
	"scripts": {
		"package": "vsce package --out themes.vsix",
		"publish": "vsce publish -i themes.vsix"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/arktypeio/arktype"
	},
	"engines": {
		"vscode": "^1.0.0"
	},
	"categories": [
		"Themes"
	],
	"icon": "../icon.png",
	"contributes": {
		"themes": [
			{
				"label": "ArkLight",
				"uiTheme": "vs",
				"path": "./arklight.json"
			},
			{
				"label": "ArkLight (italic)",
				"uiTheme": "vs",
				"path": "./arklightItalic.json"
			}
		]
	}
}
