{
	"name": "arkdark",
	"displayName": "ArkDark",
	"description": "Dark theme with special highlighting for TypeScript generics ⛵",
	"version": "6.0.0",
	"publisher": "arktypeio",
	"license": "MIT",
	"scripts": {
		"package": "vsce package --out themes.vsix",
		"publish": "vsce publish -i themes.vsix"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/arktypeio/arktype"
	},
	"engines": {
		"vscode": "^1.0.0"
	},
	"categories": [
		"Themes"
	],
	"icon": "../../icon.png",
	"contributes": {
		"themes": [
			{
				"label": "ArkDark",
				"uiTheme": "vs-dark",
				"path": "./themes/arkdark.json"
			},
			{
				"label": "ArkDark (italic)",
				"uiTheme": "vs-dark",
				"path": "./themes/arkdarkItalic.json"
			},
			{
				"label": "ArkLight",
				"uiTheme": "vs",
				"path": "./themes/arklight.json"
			},
			{
				"label": "ArkLight (italic)",
				"uiTheme": "vs",
				"path": "./themes/arklightItalic.json"
			}
		]
	}
}
