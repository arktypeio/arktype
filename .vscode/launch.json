// A launch configuration that launches the extension inside a new window
{
	"version": "0.1.0",
	"configurations": [
		{
			"name": "ArkDark Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceRoot}/ark/extensions/dark"
			]
		},
		{
			"name": "ArkLight Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceRoot}/ark/extensions/light"
			]
		},
		{
			"name": "ArkType Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceRoot}/ark/extensions/type"
			]
		}
	]
}
